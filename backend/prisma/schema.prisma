// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  USER
  MANAGER
  ADMIN
}

enum UserStatus {
  ACTIVE
  LOCKED
}

enum VenueStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum BookingStatus {
  PENDING_PAYMENT
  WAITING_MANAGER_CONFIRM
  CONFIRMED
  CANCELLED_BY_USER
  CANCELLED_BY_MANAGER
  EXPIRED
  COMPLETED
}

enum PaymentMethod {
  CASH
  TRANSFER
}

// Phase 5: Chat sender role
enum SenderRole {
  USER
  MANAGER
}

// Phase 6: Notification enums
enum NotificationTargetRole {
  USER
  MANAGER
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_REJECTED
  PAYMENT_CONFIRMED
  CHAT_MESSAGE
  REVIEW_CREATED
  SYSTEM
}

// ==================== CORE MODELS ====================

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  name            String?
  role            UserRole  @default(USER)
  isEmailVerified Boolean   @default(false)
  status          UserStatus @default(ACTIVE)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  otpVerifications OtpVerification[]
  manager          Manager?
  bookings         Booking[]
  reviews          Review[]
  chatMessages     ChatMessage[]
  // Phase 5: Chat thread relations
  chatThreadsAsUser    ChatThread[] @relation("ThreadUser")
  chatThreadsAsManager ChatThread[] @relation("ThreadManager")

  @@map("users")
}

model OtpVerification {
  id        String   @id @default(uuid())
  userId    String
  otpCode   String   // Plain text for dev mode
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_verifications")
}

model Manager {
  id                    String    @id @default(uuid())
  userId                String    @unique
  displayName           String
  subscriptionExpiresAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue?

  @@map("managers")
}

model Venue {
  id           String      @id @default(uuid())
  managerId    String      @unique
  name         String
  address      String
  district     String
  city         String      @default("TP.HCM")
  lat          Float
  lng          Float
  description  String?
  contactPhone String?
  status       VenueStatus @default(PENDING)
  // Phase 4: Bank info for VietQR
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  manager    Manager          @relation(fields: [managerId], references: [id], onDelete: Cascade)
  courts     Court[]
  schedules  Schedule[]
  holidays   Holiday[]
  images     VenueImage[]
  sportTypes VenueSportType[]
  // Phase 5: Reviews and Chat
  reviews     Review[]
  chatThreads ChatThread[]

  @@map("venues")
}

model SportType {
  id   String @id @default(uuid())
  code String @unique // BADMINTON, PICKLEBALL
  name String

  courts     Court[]
  venueTypes VenueSportType[]

  @@map("sport_types")
}

model VenueSportType {
  venueId     String
  sportTypeId String

  venue     Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  sportType SportType @relation(fields: [sportTypeId], references: [id], onDelete: Cascade)

  @@id([venueId, sportTypeId])
  @@map("venue_sport_types")
}

model Court {
  id           String  @id @default(uuid())
  venueId      String
  sportTypeId  String
  name         String  // "Sân 1", "Sân 2"
  pricePerHour Int     // VND
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  venue     Venue           @relation(fields: [venueId], references: [id], onDelete: Cascade)
  sportType SportType       @relation(fields: [sportTypeId], references: [id], onDelete: Cascade)
  bookings  Booking[]
  blackouts CourtBlackout[]

  @@map("courts")
}

model Schedule {
  id        String @id @default(uuid())
  venueId   String
  dayOfWeek Int    // 0 = Sunday, 1 = Monday, ...
  openTime  String // "06:00"
  closeTime String // "22:00"

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@map("schedules")
}

model Holiday {
  id      String   @id @default(uuid())
  venueId String
  date    DateTime @db.Date
  note    String?

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@map("holidays")
}

model VenueImage {
  id        String   @id @default(uuid())
  venueId   String
  url       String
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@map("venue_images")
}

// ==================== BOOKING MODELS (Placeholder) ====================

model Booking {
  id              String        @id @default(uuid())
  courtId         String
  userId          String
  date            DateTime      @db.Date
  startTime       String        // "18:00"
  endTime         String        // "20:00"
  durationHours   Int
  totalPrice      Int           // VND
  status          BookingStatus @default(PENDING_PAYMENT)
  paymentMethod   PaymentMethod?
  pendingExpiresAt DateTime?
  holdId          String?       @unique  // Phase 3: UUID for idempotency
  expiredAt       DateTime?              // Phase 3: When marked EXPIRED (for 30s delay)
  cancelReason    String?
  // Phase 4: Manager confirmation fields
  paymentDeclaredAt   DateTime?  // When user ticks "đã chuyển khoản"
  waitingConfirmSince DateTime?  // When entered WAITING_MANAGER_CONFIRM
  managerDecisionAt   DateTime?  // When manager confirm/cancel
  managerCancelReason String?    // Required when CANCELLED_BY_MANAGER
  confirmedAt         DateTime?  // When CONFIRMED
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  court        Court         @relation(fields: [courtId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment      Payment?
  review       Review?
  chatThread   ChatThread?

  @@index([courtId, date])
  @@index([courtId, status])
  @@index([userId, status])              // Phase 3: For user booking count
  @@index([status, waitingConfirmSince]) // Phase 4: For 1h timeout scheduler
  @@map("bookings")
}

// ==================== COURT BLACKOUT (Phase 2) ====================

model CourtBlackout {
  id        String   @id @default(uuid())
  courtId   String
  date      DateTime @db.Date         // VN local date
  startTime String   // "08:00"
  endTime   String   // "12:00"
  reason    String?
  createdAt DateTime @default(now())

  court Court @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@index([courtId, date])
  @@map("court_blackouts")
}

model Payment {
  id              String        @id @default(uuid())
  bookingId       String        @unique
  method          PaymentMethod
  amount          Int
  transferTicked  Boolean       @default(false)
  confirmedAt     DateTime?
  createdAt       DateTime      @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Review {
  id        String   @id @default(uuid())
  bookingId String   @unique
  userId    String
  venueId   String                    // Phase 5: for venue queries
  rating    Int                       // 1-5
  comment   String?  @db.VarChar(300) // Phase 5: 300 chars
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt       // Phase 5

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue   Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade) // Phase 5

  @@index([venueId, createdAt])       // Phase 5
  @@index([userId, createdAt])        // Phase 5
  @@map("reviews")
}

// ==================== CHAT MODELS (Phase 5) ====================

model ChatThread {
  id                 String    @id @default(uuid())
  bookingId          String    @unique
  userId             String                    // Phase 5: User.id (booking owner)
  managerUserId      String                    // Phase 5: User.id (manager's user account)
  venueId            String                    // Phase 5
  lastMessageAt      DateTime?                 // Phase 5
  userUnreadCount    Int       @default(0)     // Phase 5
  managerUnreadCount Int       @default(0)     // Phase 5
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt      // Phase 5

  booking  Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user     User          @relation("ThreadUser", fields: [userId], references: [id])     // Phase 5
  manager  User          @relation("ThreadManager", fields: [managerUserId], references: [id]) // Phase 5
  venue    Venue         @relation(fields: [venueId], references: [id])   // Phase 5
  messages ChatMessage[]

  @@index([managerUserId, lastMessageAt])  // Phase 5: for inbox query
  @@map("chat_threads")
}

model ChatMessage {
  id           String     @id @default(uuid())
  threadId     String
  senderUserId String                    // Phase 5: always User.id
  senderRole   SenderRole                // Phase 5: enum USER|MANAGER
  content      String     @db.VarChar(1000)  // Phase 5: 1000 chars
  createdAt    DateTime   @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User       @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])  // Phase 5
  @@map("chat_messages")
}

// ==================== AUDIT LOG (Placeholder) ====================

model AuditLog {
  id         String   @id @default(uuid())
  eventType  String
  actorId    String?
  actorEmail String?
  actorRole  String?
  action     String
  targetType String?
  targetId   String?
  details    Json?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

// ==================== PHASE 6: NOTIFICATIONS ====================

model Notification {
  id         String                 @id @default(uuid())
  type       NotificationType
  role       NotificationTargetRole
  userId     String?                // when role=USER
  managerId  String?                // when role=MANAGER
  venueId    String?
  bookingId  String?
  title      String
  body       String
  isRead     Boolean                @default(false)
  createdAt  DateTime               @default(now())

  @@index([role, userId, isRead, createdAt])
  @@index([role, managerId, isRead, createdAt])
  @@index([bookingId])
  @@map("notifications")
}
